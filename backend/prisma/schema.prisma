generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  GESTOR
  ANALISTA
}

enum CompanyPlan {
  TRIAL
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum TicketStatus {
  ABERTO
  EM_ANDAMENTO
  PENDENTE
  CONCLUIDO
  CANCELADO
}

enum TicketPriority {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum SlaStatus {
  OK
  EM_RISCO
  VIOLADO
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  ASSIGN
  REASSIGN
  CLOSE
  REOPEN
}

enum AuditEntity {
  TICKET
  USER
  COMPANY
  SLARULE
  IMPORTBATCH
  AUTH
}

model Company {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  cnpj      String?  @unique
  active    Boolean  @default(true)
  plan      CompanyPlan        @default(TRIAL)
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  seatLimit Int      @default(5)
  monthlyTicketLimit Int @default(200)
  trialEndsAt DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  tickets   Ticket[]
  slaRules  SlaRule[]
  auditLogs AuditLog[]
  alerts    Alert[]

  @@map("companies")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(ANALISTA)
  active    Boolean  @default(true)
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company?        @relation(fields: [companyId], references: [id])
  assignedTickets Ticket[]        @relation("AssignedTechnician")
  createdTickets  Ticket[]        @relation("CreatedBy")
  importBatches   ImportBatch[]
  auditLogs       AuditLog[]
  alerts          Alert[]

  @@map("users")
}

model SlaRule {
  id            String         @id @default(uuid())
  name          String
  priority      TicketPriority
  responseTime  Int            // minutos para primeira resposta
  resolutionTime Int           // minutos para resolução
  companyId     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company Company? @relation(fields: [companyId], references: [id])
  tickets Ticket[]

  @@map("sla_rules")
}

model Ticket {
  id               String         @id @default(uuid())
  externalId       String?        // ID original do sistema importado
  title            String
  description      String?
  status           TicketStatus   @default(ABERTO)
  priority         TicketPriority @default(MEDIA)
  category         String?
  sector           String?
  companyId        String?
  assignedToId     String?
  createdById      String?
  slaRuleId        String?
  slaStatus        SlaStatus      @default(OK)
  openedAt         DateTime       @default(now())
  firstResponseAt  DateTime?
  resolvedAt       DateTime?
  slaDeadline      DateTime?
  slaResponseDeadline DateTime?
  importBatchId    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  company      Company?      @relation(fields: [companyId], references: [id])
  assignedTo   User?         @relation("AssignedTechnician", fields: [assignedToId], references: [id])
  createdBy    User?         @relation("CreatedBy", fields: [createdById], references: [id])
  slaRule      SlaRule?      @relation(fields: [slaRuleId], references: [id])
  importBatch  ImportBatch?  @relation(fields: [importBatchId], references: [id])
  alerts       Alert[]

  @@map("tickets")
}

model ImportBatch {
  id          String   @id @default(uuid())
  filename    String
  totalRows   Int      @default(0)
  importedRows Int     @default(0)
  errorRows   Int      @default(0)
  status      String   @default("PROCESSANDO") // PROCESSANDO, CONCLUIDO, ERRO
  mapping     Json?    // mapeamento de colunas
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User?    @relation(fields: [userId], references: [id])
  tickets Ticket[]

  @@map("import_batches")
}

model AuditLog {
  id            String        @id @default(uuid())
  action        AuditAction
  entity        AuditEntity
  entityId      String        // ID do recurso auditado (ticket, user, etc)
  companyId     String        // Isolamento multi-tenant
  userId        String?       // Quem realizou a ação
  changes       Json?         // Antes e depois (para UPDATE)
  description   String?       // Descrição legível da ação
  ipAddress     String?       // IP de origem (LGPD)
  userAgent     String?       // User agent (LGPD)
  createdAt     DateTime      @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// Alertas Inteligentes para SLA e Sobrecarga
enum AlertType {
  SLA_EM_RISCO      // Ticket com SLA próximo do vencimento
  SLA_VIOLADO       // Ticket com SLA já vencido
  EQUIPE_SOBRECARREGADA  // Técnico com muitos tickets abertos
  TICKET_CRITICO    // Ticket crítico não atribuído/bloqueado
  FILA_CRITICA      // Muitos tickets aguardando atribuição
}

enum AlertSeverity {
  INFO
  AVISO
  CRITICO
  BLOQUEADOR
}

model Alert {
  id String @id @default(uuid())
  
  // Contextualização
  type AlertType
  severity AlertSeverity
  companyId String
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Identificação do problema
  ticketId String?
  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  
  userId String? // Técnico sobrecarregado
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Dados do alerta
  title String // "SLA em risco: Ticket #123"
  description String // Descrição detalhada do problema
  
  // Métricas para análise
  metrics Json? // { slaPercentUsed: 75, ticketCount: 12, estimatedMinutes: 30 }
  
  // Status
  acknowledged Boolean @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolved Boolean @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  
  // Rastreamento
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([ticketId])
  @@index([userId])
  @@index([type])
  @@index([severity])
  @@index([acknowledged])
  @@index([resolved])
  @@index([createdAt])
  @@map("alerts")
}

